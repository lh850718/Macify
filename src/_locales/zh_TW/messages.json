  "video_apple_help_title": {
    "message": "為什麼蘋果伺服器可能需要額外設定?"
  },
  "video_apple_help_intro": {
    "message": "Chrome 不一定信任蘋果 sylvan.apple.com 的憑證,直連影片可能失敗。兩種解決方案:"
  },
  "video_apple_help_option1_title": {
    "message": "方案 1 — 啟用反向代理(簡單)"
  },
  "video_apple_help_option1_body": {
    "message": "勾選上方「使用反向代理」,Macify 會透過 Cloudflare Worker 代為請求並處理憑證問題。無需任何本地設定。"
  },
  "video_apple_help_option2_title": {
    "message": "方案 2 — 手動信任蘋果憑證(最乾淨)"
  },
  "video_apple_help_option2_body_pre": {
    "message": "在 Chrome 裡開啟"
  },
  "video_apple_help_option2_body_post": {
    "message": "一次。會出現安全性警告——點「進階」,然後點「繼續前往 sylvan.apple.com(不安全)」。Chrome 會記住你的信任,之後直連就沒問題了。"
  },
  "video_local_help_title": {
    "message": "架設本地 Apache 伺服器(一次性設定)"
  },
  "video_local_macos_only": {
    "message": "提示：以下步驟基於 macOS 內建的 Apache。其他系統可以用任何支援目錄列表和 CORS 的 HTTP 伺服器替代，自行調整指令即可。"
  },
  "video_local_step1": {
    "message": "在終端中執行以下指令，自動設定 macOS 內建的 Apache 來服務空拍影片。中途會提示輸入一次密碼。"
  },
  "video_local_step2": {
    "message": "下載影片。有兩種方式："
  },
  "video_local_step2_manual_title": {
    "message": "手動下載"
  },
  "video_local_step2_manual_body": {
    "message": "開啟系統設定 → 螢幕保護程式 → 空拍，點擊你想下載的影片。每個 500 MB – 1 GB，下載較慢且可能需要重試。"
  },
  "video_local_step2_script_title": {
    "message": "一鍵下載腳本"
  },
  "video_local_step2_script_body": {
    "message": "在終端中執行以下指令，依提示操作即可。腳本會先估算下載大小和你的可用磁碟空間，徵得確認後再開始。"
  },
  "video_local_step3_pre": {
    "message": "上方預設位址("
  },
  "video_local_step3_post": {
    "message": ")現在應該能列出你下載的影片了。"
  },
