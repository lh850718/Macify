<view class="settings-page">
  <view class="header">
    <text class="title" bindtap="openLicenses">© 呼吸Zen</text>
    <text class="subtitle">安静的呼吸与风景</text>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">显示</text>
    </view>
    <view class="setting-row">
      <view class="row-copy">
        <text class="label">时间</text>
      </view>
      <switch checked="{{settings.showClock}}" data-key="showClock" bindchange="onSwitchChange" color="#47c7a2" />
    </view>
    <view class="setting-row">
      <view class="row-copy">
        <text class="label">天气</text>
      </view>
      <switch checked="{{settings.showWeather}}" data-key="showWeather" bindchange="onSwitchChange" color="#47c7a2" />
    </view>
    <view class="weather-inline-row" wx:if="{{settings.showWeather}}">
      <input
        class="weather-city-input"
        name="city"
        value="{{settings.city}}"
        placeholder="北京"
        bindinput="onCityInput"
        bindblur="onCityBlur"
      />
      <radio-group class="weather-unit-segment" bindchange="onTempUnitChange">
        <label class="weather-unit-option {{tempIsCelsius ? 'weather-unit-option-active' : ''}}">
          <radio class="weather-unit-radio" value="celsius" checked="{{tempIsCelsius}}" color="#47c7a2" />
          <text class="weather-unit-text">摄氏度</text>
        </label>
        <label class="weather-unit-option {{tempIsFahrenheit ? 'weather-unit-option-active' : ''}}">
          <radio class="weather-unit-radio" value="fahrenheit" checked="{{tempIsFahrenheit}}" color="#47c7a2" />
          <text class="weather-unit-text">华氏度</text>
        </label>
      </radio-group>
    </view>
    <view class="setting-row">
      <view class="row-copy">
        <text class="label">语录</text>
      </view>
      <switch checked="{{settings.showQuote}}" data-key="showQuote" bindchange="onSwitchChange" color="#47c7a2" />
    </view>
    <view class="setting-row">
      <view class="row-copy">
        <text class="label">视频信息</text>
      </view>
      <switch checked="{{settings.showVideoMeta}}" data-key="showVideoMeta" bindchange="onSwitchChange" color="#47c7a2" />
    </view>
    <view class="setting-row stacked-row">
      <view class="row-copy">
        <text class="label">保留呼吸页设置</text>
        <text class="hint">仅保留颂钵音和触感；退出后重新进入仍先静音</text>
      </view>
      <switch checked="{{settings.rememberZenCues}}" data-key="rememberZenCues" bindchange="onSwitchChange" color="#47c7a2" />
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">呼吸节奏</text>
    </view>

    <view class="breath-rhythm-block">
      <text class="label">默认呼吸</text>
      <view class="rhythm-formula rhythm-default-formula">
        <text class="rhythm-label-cell rhythm-cell-1">吸气</text>
        <text class="rhythm-label-cell rhythm-cell-3">屏息</text>
        <text class="rhythm-label-cell rhythm-cell-5">呼气</text>
        <text class="rhythm-label-cell rhythm-cell-7">屏息</text>
        <input
          class="rhythm-compact-input rhythm-cell-1 rhythm-input-line"
          type="number"
          maxlength="2"
          value="{{settings.defaultBreathRhythm.inhale}}"
          data-rhythm="defaultBreathRhythm"
          data-field="inhale"
          bindinput="onBreathRhythmInput"
          bindblur="onBreathRhythmBlur"
        />
        <text class="rhythm-separator rhythm-cell-2 rhythm-input-line">→</text>
        <input
          class="rhythm-compact-input rhythm-cell-3 rhythm-input-line"
          type="number"
          maxlength="2"
          value="{{settings.defaultBreathRhythm.holdAfterInhale}}"
          data-rhythm="defaultBreathRhythm"
          data-field="holdAfterInhale"
          bindinput="onBreathRhythmInput"
          bindblur="onBreathRhythmBlur"
        />
        <text class="rhythm-separator rhythm-cell-4 rhythm-input-line">→</text>
        <input
          class="rhythm-compact-input rhythm-cell-5 rhythm-input-line"
          type="number"
          maxlength="2"
          value="{{settings.defaultBreathRhythm.exhale}}"
          data-rhythm="defaultBreathRhythm"
          data-field="exhale"
          bindinput="onBreathRhythmInput"
          bindblur="onBreathRhythmBlur"
        />
        <text class="rhythm-separator rhythm-cell-6 rhythm-input-line">→</text>
        <input
          class="rhythm-compact-input rhythm-cell-7 rhythm-input-line"
          type="number"
          maxlength="2"
          value="{{settings.defaultBreathRhythm.holdAfterExhale}}"
          data-rhythm="defaultBreathRhythm"
          data-field="holdAfterExhale"
          bindinput="onBreathRhythmInput"
          bindblur="onBreathRhythmBlur"
        />
        <text class="rhythm-unit-tail rhythm-cell-8 rhythm-input-line">秒</text>
      </view>
    </view>

    <view class="breath-rhythm-block">
      <text class="label">自定义练习</text>
      <view class="rhythm-formula rhythm-custom-formula">
        <text class="rhythm-label-cell rhythm-cell-1">吸气</text>
        <text class="rhythm-label-cell rhythm-cell-3">屏息</text>
        <text class="rhythm-label-cell rhythm-cell-5">呼气</text>
        <text class="rhythm-label-cell rhythm-cell-7">屏息</text>
        <text class="rhythm-label-cell rhythm-cell-9">组数</text>
        <input
          class="rhythm-compact-input rhythm-cell-1 rhythm-input-line"
          type="number"
          maxlength="2"
          value="{{settings.customBreathRhythm.inhale}}"
          data-rhythm="customBreathRhythm"
          data-field="inhale"
          bindinput="onBreathRhythmInput"
          bindblur="onBreathRhythmBlur"
        />
        <text class="rhythm-separator rhythm-cell-2 rhythm-input-line">→</text>
        <input
          class="rhythm-compact-input rhythm-cell-3 rhythm-input-line"
          type="number"
          maxlength="2"
          value="{{settings.customBreathRhythm.holdAfterInhale}}"
          data-rhythm="customBreathRhythm"
          data-field="holdAfterInhale"
          bindinput="onBreathRhythmInput"
          bindblur="onBreathRhythmBlur"
        />
        <text class="rhythm-separator rhythm-cell-4 rhythm-input-line">→</text>
        <input
          class="rhythm-compact-input rhythm-cell-5 rhythm-input-line"
          type="number"
          maxlength="2"
          value="{{settings.customBreathRhythm.exhale}}"
          data-rhythm="customBreathRhythm"
          data-field="exhale"
          bindinput="onBreathRhythmInput"
          bindblur="onBreathRhythmBlur"
        />
        <text class="rhythm-separator rhythm-cell-6 rhythm-input-line">→</text>
        <input
          class="rhythm-compact-input rhythm-cell-7 rhythm-input-line"
          type="number"
          maxlength="2"
          value="{{settings.customBreathRhythm.holdAfterExhale}}"
          data-rhythm="customBreathRhythm"
          data-field="holdAfterExhale"
          bindinput="onBreathRhythmInput"
          bindblur="onBreathRhythmBlur"
        />
        <text class="rhythm-separator rhythm-cell-8 rhythm-input-line">秒 ×</text>
        <input
          class="rhythm-compact-input rhythm-cell-9 rhythm-input-line"
          type="number"
          maxlength="2"
          value="{{settings.customBreathRhythm.cycles}}"
          data-rhythm="customBreathRhythm"
          data-field="cycles"
          bindinput="onBreathRhythmInput"
          bindblur="onBreathRhythmBlur"
        />
        <text class="rhythm-unit-tail rhythm-cell-10 rhythm-input-line">组</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">背景视频</text>
    </view>
    <view class="scope-field">
      <text class="label">播放范围</text>
      <view class="scope-grid">
        <view
          class="scope-chip {{item.selected ? 'scope-chip-active' : ''}}"
          wx:for="{{categoryOptions}}"
          wx:key="value"
          data-value="{{item.value}}"
          bindtap="onCategoryTap"
          hover-class="tap-soft"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">视频背景音</text>
    </view>
    <radio-group class="audio-mode-segment" bindchange="onAmbientAudioModeChange">
      <label class="audio-mode-option {{ambientAudioModeIsVideo ? 'audio-mode-option-active' : ''}}">
        <radio class="audio-mode-radio" value="video" checked="{{ambientAudioModeIsVideo}}" color="#47c7a2" />
        <text class="audio-mode-text">视频自带音频</text>
      </label>
      <label class="audio-mode-option {{ambientAudioModeIsCustom ? 'audio-mode-option-active' : ''}}">
        <radio class="audio-mode-radio" value="custom" checked="{{ambientAudioModeIsCustom}}" color="#47c7a2" />
        <text class="audio-mode-text">自定义混音</text>
      </label>
    </radio-group>

    <view class="audio-mix-panel" wx:if="{{ambientAudioModeIsCustom}}">
      <view class="audio-mix-toolbar">
        <text class="audio-mix-count">{{ambientSelectedLimitText}}</text>
        <view
          class="audition-button {{ambientAuditionOn ? 'audition-button-active' : ''}}"
          bindtap="toggleAmbientAudition"
          hover-class="tap-soft"
        >{{ambientAuditionOn ? '停止试听' : '开始试听'}}</view>
      </view>

      <view class="audio-track-list">
        <view
          class="audio-track-row {{item.selected ? 'audio-track-row-active' : ''}} {{item.disabled ? 'audio-track-row-disabled' : ''}}"
          wx:for="{{customAmbientTracks}}"
          wx:key="id"
        >
          <view
            class="audio-track-name"
            data-track-id="{{item.id}}"
            bindtap="onCustomTrackTap"
            hover-class="tap-soft"
          >
            <text>{{item.label}}</text>
          </view>
          <slider
            wx:if="{{item.selected}}"
            class="audio-volume-slider"
            min="0"
            max="100"
            step="1"
            value="{{item.volumePercent}}"
            activeColor="#47c7a2"
            backgroundColor="#d8e0e3"
            block-color="#ffffff"
            block-size="18"
            data-track-id="{{item.id}}"
            bindchanging="onCustomTrackVolumeChanging"
            bindchange="onCustomTrackVolumeChange"
          />
        </view>
      </view>
    </view>
  </view>

  <view class="save-return-bar">
    <view class="save-return-button" bindtap="saveAndReturn" hover-class="tap-soft">保存返回</view>
  </view>
</view>
