# Copy to .env (gitignored) and fill in your values. .env.local also works
# — Vite reads both. Vite only exposes vars prefixed with VITE_ to client
# code; non-prefixed vars are silently ignored.

# ---------------------------------------------------------------------------
# Donate prompt interval (milliseconds). Defaults to 7 days when unset.
# Useful values for testing:
#   10000      -> 10 seconds
#   60000      -> 1 minute
#   3600000    -> 1 hour
#   86400000   -> 1 day
#   604800000  -> 7 days (production default)
#
# VITE_DONATE_INTERVAL_MS=60000

# ---------------------------------------------------------------------------
# Zen mode music base URL. Each maintainer hosts their own bucket — the
# canonical URL is intentionally NOT committed to source. If unset, zen
# mode degrades to "fullscreen without music" with no error.
#
# Expected layout: <BASE>music00001.mp3 ... <BASE>music00040.mp3
# Trailing slash required.
#
# VITE_ZENMODE_MUSIC_URL=https://your-bucket.example.com/music/
