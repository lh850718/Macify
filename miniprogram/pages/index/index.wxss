.screen {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #05070a;
}

.poster,
.aerial-video {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
}

.poster {
  filter: saturate(1.08);
}

.aerial-video {
  z-index: 1;
}

.shade {
  position: fixed;
  inset: 0;
  z-index: 2;
  background:
    linear-gradient(180deg, rgba(0, 0, 0, 0.34), rgba(0, 0, 0, 0.08) 42%, rgba(0, 0, 0, 0.46)),
    linear-gradient(90deg, rgba(0, 0, 0, 0.28), transparent 38%, rgba(0, 0, 0, 0.22));
}

.topbar {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 24rpx);
  left: 28rpx;
  right: 28rpx;
  z-index: 5;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.meta,
.weather {
  min-width: 0;
  max-width: 46vw;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.meta {
  padding: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.weather {
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  margin-top: 92rpx;
}

.meta-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 1.15;
  text-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.55);
}

.weather-temp {
  color: #fff;
  font-size: 30rpx;
  font-weight: 650;
  line-height: 1.15;
}

.meta-sub,
.weather-copy {
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1.3;
}

.weather {
  align-items: flex-end;
  text-align: right;
}

.center {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  top: 44vh;
  z-index: 4;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 42rpx;
  text-align: center;
}

.clock-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.clock {
  color: #fff;
  font-size: 128rpx;
  font-weight: 700;
  line-height: 1;
  text-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.4);
}

.date {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  letter-spacing: 0;
}

.quote {
  max-width: 620rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  color: rgba(255, 255, 255, 0.88);
  text-shadow: 0 6rpx 28rpx rgba(0, 0, 0, 0.44);
}

.quote-content {
  font-size: 30rpx;
  line-height: 1.48;
}

.quote-author {
  color: rgba(255, 255, 255, 0.66);
  font-size: 22rpx;
}

.bottom-actions {
  position: fixed;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 32rpx);
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 22rpx;
  width: auto;
  max-width: 160rpx;
}

.icon-button {
  width: 58rpx;
  height: 58rpx;
  padding: 0;
  box-sizing: border-box;
  color: rgba(255, 255, 255, 0.72);
  font-size: 34rpx;
  line-height: 58rpx;
  text-align: center;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.55);
}

.refresh-button {
  font-size: 32rpx;
}

.dots-button {
  font-size: 36rpx;
  letter-spacing: 2rpx;
}

.toast {
  position: fixed;
  left: 50%;
  bottom: calc(env(safe-area-inset-bottom) + 148rpx);
  z-index: 6;
  transform: translateX(-50%);
  max-width: 620rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  color: #fff;
  font-size: 24rpx;
  text-align: center;
}
