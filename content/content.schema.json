{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huxizen.com/schemas/macify-content.schema.json",
  "title": "Macify shared content schema",
  "type": "object",
  "$defs": {
    "config": {
      "type": "object",
      "required": [
        "schemaVersion",
        "contentVersion",
        "defaultVideoLibrary",
        "defaultVideoBase",
        "defaultAmbientAudioBase"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "contentVersion": { "type": "string", "minLength": 1 },
        "defaultVideoLibrary": { "type": "string", "minLength": 1 },
        "defaultVideoBase": { "type": "string", "format": "uri" },
        "defaultAmbientAudioBase": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "video": {
      "type": "object",
      "required": [
        "id",
        "name",
        "displayName",
        "locationName",
        "locationCountry",
        "sourceName",
        "sourcePage",
        "sourceDownloadPage",
        "url",
        "previewImage",
        "category",
        "subcategories",
        "tags",
        "timeOfDay",
        "description",
        "sourceResolution",
        "duration",
        "license",
        "attribution",
        "licenseNotes",
        "qualityTier"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "displayName": { "type": "string" },
        "locationName": { "type": "string" },
        "locationCountry": { "type": "string" },
        "sourceName": {
          "enum": ["Mixkit", "Pexels", "Pixabay", "Dareful", "Coverr"]
        },
        "sourcePage": { "type": "string", "format": "uri" },
        "sourceDownloadPage": { "type": "string", "format": "uri" },
        "url": { "type": "string", "format": "uri" },
        "previewImage": { "type": "string", "format": "uri" },
        "category": {
          "enum": ["Landscapes", "Underwater", "AnimalsAndPlants", "Motion"]
        },
        "subcategories": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "timeOfDay": { "type": "string" },
        "description": { "type": "string" },
        "sourceResolution": { "type": "string" },
        "duration": { "type": "string" },
        "license": { "type": "string" },
        "attribution": { "type": "string" },
        "licenseNotes": { "type": "string" },
        "qualityTier": {
          "enum": ["candidate", "sample-approved", "rejected", "published"]
        }
      },
      "additionalProperties": true
    },
    "ambientTrack": {
      "type": "object",
      "required": ["id", "label", "file", "durationMs", "volume"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "file": { "type": "string", "pattern": "\\.mp3$" },
        "durationMs": { "type": "integer", "minimum": 1 },
        "volume": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "ambientRule": {
      "type": "object",
      "required": ["trackId", "any"],
      "properties": {
        "trackId": { "type": "string", "minLength": 1 },
        "any": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "none": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "trackSpec": {
      "type": "object",
      "required": ["trackId"],
      "properties": {
        "trackId": { "type": "string", "minLength": 1 },
        "volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "label": { "type": "string" }
      },
      "additionalProperties": false
    },
    "videoAudioMix": {
      "type": "object",
      "required": ["videoId", "mix", "notes"],
      "properties": {
        "videoId": { "type": "string", "minLength": 1 },
        "mix": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/trackSpec" }
            }
          ]
        },
        "notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
