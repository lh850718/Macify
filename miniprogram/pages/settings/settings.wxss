.settings-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 28rpx) 28rpx calc(env(safe-area-inset-bottom) + 48rpx);
  box-sizing: border-box;
  background:
    linear-gradient(180deg, #e8f4f1 0%, #f6f8fb 34%, #f3f5f7 100%);
  color: #15222b;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  display: block;
  color: #15222b;
  font-size: 44rpx;
  font-weight: 750;
  line-height: 1.1;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: #6e7c86;
  font-size: 24rpx;
}

.section {
  margin-bottom: 22rpx;
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(21, 34, 43, 0.06);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 34rpx rgba(34, 58, 72, 0.07);
  overflow: hidden;
}

.section-head {
  min-height: 70rpx;
  display: flex;
  align-items: center;
}

.section-title {
  color: #7a8792;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.3;
}

.setting-row {
  min-height: 98rpx;
  border-top: 1rpx solid rgba(21, 34, 43, 0.07);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.stacked-row {
  min-height: 112rpx;
  padding: 16rpx 0;
}

.row-copy {
  min-width: 0;
  flex: 1;
}

.field-block {
  border-top: 1rpx solid rgba(21, 34, 43, 0.07);
  padding: 18rpx 0 20rpx;
}

.field-label-row {
  margin-bottom: 14rpx;
}

.label {
  display: block;
  color: #1d2c36;
  font-size: 28rpx;
  font-weight: 630;
  line-height: 1.35;
}

.value {
  color: #6e7c86;
  font-size: 26rpx;
}

.hint {
  display: block;
  margin-top: 7rpx;
  color: #8d99a3;
  font-size: 22rpx;
  line-height: 1.45;
}

.input {
  width: 100%;
  height: 78rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(31, 67, 78, 0.1);
  border-radius: 18rpx;
  background: #f6faf9;
  color: #15222b;
  font-size: 26rpx;
  line-height: 78rpx;
}

.unit-segment {
  min-height: 82rpx;
  border-top: 1rpx solid rgba(21, 34, 43, 0.07);
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 0 20rpx;
}

.unit-option {
  position: relative;
  height: 70rpx;
  flex: 1;
  border-radius: 18rpx;
  background: #f2f5f7;
  color: #64727c;
  font-size: 26rpx;
  font-weight: 580;
  line-height: 70rpx;
  text-align: center;
  box-shadow: inset 0 0 0 1rpx rgba(31, 67, 78, 0.06);
}

.unit-option-active {
  background: #14333a;
  color: #ecfffa;
  box-shadow: 0 10rpx 22rpx rgba(20, 51, 58, 0.16);
}

.unit-radio {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
}

.unit-text {
  display: block;
}

.scope-field {
  border-top: 1rpx solid rgba(21, 34, 43, 0.07);
  padding: 20rpx 0 24rpx;
}

.scope-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx 12rpx;
}

.scope-chip {
  min-height: 70rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(31, 67, 78, 0.09);
  border-radius: 18rpx;
  background: #f6f8fa;
  color: #53636e;
  font-size: 25rpx;
  font-weight: 580;
  line-height: 70rpx;
  text-align: center;
  transition: opacity 120ms ease;
}

.scope-chip-active {
  border-color: rgba(31, 143, 117, 0.38);
  background: #e7f7f1;
  color: #16745f;
  font-weight: 700;
  box-shadow: inset 0 0 0 1rpx rgba(31, 143, 117, 0.08);
}

.tap-soft {
  opacity: 0.76;
}
