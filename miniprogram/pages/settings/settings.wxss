.settings-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 40rpx) 28rpx calc(env(safe-area-inset-bottom) + 48rpx);
  box-sizing: border-box;
  background: #f4f6f8;
  color: #18202a;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 750;
  line-height: 1.1;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: #687382;
  font-size: 24rpx;
}

.section {
  margin-bottom: 24rpx;
  padding: 4rpx 24rpx;
  background: #fff;
  border: 1rpx solid #e6eaf0;
  border-radius: 16rpx;
}

.section-title {
  padding: 24rpx 0 10rpx;
  color: #687382;
  font-size: 22rpx;
  font-weight: 650;
}

.row,
.field {
  min-height: 94rpx;
  border-top: 1rpx solid #eef1f5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.stacked-row {
  align-items: flex-start;
  padding: 18rpx 0;
}

.library-field {
  border-top: 1rpx solid #eef1f5;
  padding: 22rpx 0;
}

.field {
  align-items: flex-start;
  flex-direction: column;
  justify-content: center;
  padding: 18rpx 0;
}

.label {
  color: #26313f;
  font-size: 28rpx;
  font-weight: 560;
}

.value {
  color: #687382;
  font-size: 26rpx;
}

.hint {
  display: block;
  margin-top: 8rpx;
  color: #8b95a3;
  font-size: 22rpx;
  line-height: 1.35;
}

.input {
  width: 100%;
  height: 72rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border: 1rpx solid #dfe5ec;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #18202a;
  font-size: 26rpx;
}

.radio-row {
  min-height: 94rpx;
  border-top: 1rpx solid #eef1f5;
  display: flex;
  align-items: center;
  gap: 34rpx;
}

.video-source-row {
  min-height: auto;
  padding: 22rpx 0;
  align-items: flex-start;
  flex-wrap: wrap;
  row-gap: 18rpx;
}

.video-library-row {
  min-height: auto;
  margin-top: 18rpx;
  border-top: none;
  flex-wrap: wrap;
  row-gap: 18rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #26313f;
  font-size: 26rpx;
}

.scope-field {
  border-top: 1rpx solid #eef1f5;
  padding: 22rpx 0 24rpx;
}

.scope-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.scope-chip {
  min-height: 64rpx;
  border: 1rpx solid #dfe5ec;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #4d5968;
  font-size: 25rpx;
  line-height: 64rpx;
  text-align: center;
}

.scope-chip-active {
  border-color: #47c7a2;
  background: rgba(71, 199, 162, 0.12);
  color: #167a62;
  font-weight: 650;
}

.settings-actions {
  padding-top: 12rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 4rpx);
}

.save-button {
  height: 88rpx;
  margin-top: 34rpx;
  border-radius: 16rpx;
  background: #18202a;
  color: #fff;
  font-size: 28rpx;
  line-height: 88rpx;
}

.save-button::after {
  border: none;
}
